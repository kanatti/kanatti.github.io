---
import type { CollectionEntry } from "astro:content";
import clsx from "clsx";
import { seriesInfo } from "../data/series";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;

const seriesSlug = post.data.series;
const seriesOrder = post.data.seriesOrder;
const series = seriesSlug ? seriesInfo[seriesSlug] : null;

const classes = [
	// Setup Prose
	"prose prose-lg prose-slate max-w-none",
	// all headings
	"prose-headings:font-normal prose-headings:text-ink prose-headings:mt-8 prose-headings:mb-4",
	// h1
	"prose-h1:text-2xl sm:prose-h1:text-3xl prose-h1:mt-0 prose-h1:mb-6",
	// h2
	"prose-h2:text-xl sm:prose-h2:text-2xl prose-h2:mt-8 prose-h2:mb-4",
	// h3
	"prose-h3:text-lg sm:prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3",
	// h4
	"prose-h4:text-lg prose-h4:mt-6 prose-h4:mb-2",
	// p
	"prose-p:text-base sm:prose-p:text-lg prose-p:text-ink prose-p:mb-4",
	// ol
	"prose-ol:text-base sm:prose-ol:text-lg prose-ol:text-ink prose-ol:mb-4",
	// ul
	"prose-ul:text-base sm:prose-ul:text-lg prose-ul:text-ink prose-ul:mb-4",
	// li
	"prose-li:my-1 prose-li:text-ink",
	// links
	"prose-a:text-ink prose-a:underline prose-a:decoration-1 hover:prose-a:decoration-2",
	// code
	"prose-code:before:hidden prose-code:after:hidden prose-code:[font-size:0.8rem]",
	// code block
	"prose-pre:rounded-sm prose-pre:leading-normal prose-pre:py-3 prose-pre:px-4 prose-pre:mb-4 prose-pre:[font-size:0.8rem] prose-pre:bg-transparent",
	// blockquotes
	"prose-blockquote:border-l-4 prose-blockquote:border-gray-300 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-ink-light prose-blockquote:mb-4 prose-blockquote:py-0 prose-blockquote:my-4 prose-blockquote:[&>p]:my-0",
];

const articleClasses = clsx(classes);
---

<style>
	html {
		scroll-behavior: smooth;
	}
</style>

<div class="max-w-[48rem] mx-auto lg:ml-[15%] lg:mr-auto px-4 sm:px-6 pt-6 pb-12 relative">
	<!-- Main Content Area -->
	<div>
		<header class="mb-8">
			<nav class="flex space-x-6 mb-2">
				<a href="/" class="text-ink hover:underline text-lg">Home</a>
				<a href="/posts" class="text-ink hover:underline text-lg">Posts</a>
				<a href="/series" class="text-ink hover:underline text-lg">Series</a>
				<a href="/projects" class="text-ink hover:underline text-lg">Projects</a>
			</nav>
			<hr class="border-gray-600 mb-8" />
		</header>

		<article
			class={`${articleClasses} relative overflow-visible`}
			style="counter-reset: sidenote-counter;"
		>
			{series && seriesOrder && (
				<p class="text-sm text-ink-light mb-6">
					Part {seriesOrder} of <a href={`/series/${seriesSlug}`} class="text-ink underline">{series.title}</a>
				</p>
			)}
			<slot />
		</article>
	</div>
</div>
