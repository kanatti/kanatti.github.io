---
import SiteHeader from "./SiteHeader.astro";

interface Props {
    currentPage: "home" | "blog" | "projects";
}

const { currentPage } = Astro.props;
---

<div class="max-w-[42rem] mx-auto px-4 sm:px-6 pt-6 pb-12 relative">
    <header class="mb-8">
        <nav class="flex space-x-6 mb-2">
            <a href="/" class={`text-ink text-lg ${currentPage === "home" ? "underline" : "hover:underline"}`}>Home</a>
            <a href="/blog" class={`text-ink text-lg ${currentPage === "blog" ? "underline" : "hover:underline"}`}>Blog</a>
            <a href="/projects" class={`text-ink text-lg ${currentPage === "projects" ? "underline" : "hover:underline"}`}>Projects</a>
        </nav>
        <hr class="border-gray-600 mb-8" />
    </header>
    <main>
        <slot />
    </main>
</div>
